<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#C0C0C0"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PaymentActivity">

<!--    Below is textview just for the message-->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Complete the payment of your product with Mpesa"
        android:textSize="38sp"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:textColor="#010910"
        android:layout_marginTop="10dp"/>

<!--    Below is a cardview that holds all our content-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="25dp"
        android:layout_marginTop="50dp"
        android:backgroundTint="#6A5758"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        app:cardElevation="10dp"
        android:padding="10dp">

<!--        Below is a linear layout-->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

<!--            Below is a textview where the name of the product is bound-->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/txtProductName"
                android:text="Product Name"
                android:textSize="28sp"
                android:textStyle="bold|italic"
                android:textColor="#010910"/>


<!--            Below is the imageview of the product image-->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:id="@+id/imgProduct"
                android:src="@mipmap/ic_launcher"
                android:scaleType="fitXY"
                android:layout_marginTop="10dp"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"/>


<!--            The textview of the product cost-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/txtProductCost"
                android:text="KSH 1000 "
                android:layout_marginTop="10dp"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#010910"/>

            <!--            Below is a textview-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/description"
                android:text="the text description will appear here"
                android:textSize="20sp"
                android:textColor="#000"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="8dp"/>


<!--            Below is an edittext for entering mobile number-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="☎Enter your phone number eg 2547XXXXXXXX"
                android:textColorHint="#000"
                android:id="@+id/phone"
                android:textColor="#000"
                android:inputType="number"
                android:textSize="22sp"
                android:layout_margin="8dp"
                android:background="#776"
                android:padding="11dp"/>






<!--            Below is a button to complete the process-->

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/pay"
                android:text="Pay Now"
                android:backgroundTint="#28500f"
                android:layout_marginTop="8dp"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:textSize="25sp"/>


        </LinearLayout>







    </androidx.cardview.widget.CardView>



</LinearLayout>