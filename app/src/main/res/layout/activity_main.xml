<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#C0C0C0"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sokogarden"
        android:background="@drawable/shape"
        android:textSize="38sp"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:textColor="#010910"/>


<!--    below is the linear layout that aligns contents horizontally-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#800020"
            android:text="SignUp"
            android:textSize="25sp"
            android:padding="15dp"
            android:layout_weight="1"
            android:textColor="#F6C5BA9B"
            android:layout_marginLeft="5dp"
            android:layout_marginTop="8dp"
            android:id="@+id/signupBtn"/>

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#800020"
            android:text="SignIn"
            android:textSize="25sp"
            android:textColor="#F6C5BA9B"
            android:layout_weight="1"
            android:padding="15dp"
            android:layout_marginLeft="5dp"
            android:layout_marginTop="8dp"
            android:id="@+id/signinBtn"/>

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#800020"
            android:text="About"
            android:textSize="25sp"
            android:textColor="#F6C5BA9B"
            android:layout_weight="1"
            android:padding="15dp"
            android:layout_marginLeft="5dp"
            android:layout_marginTop="8dp"
            android:id="@+id/aboutBtn"/>

        <TextView
            android:id="@+id/welcomeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome"
            android:textSize="24sp"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:visibility="gone"
            android:layout_marginTop="20dp"/>

        <Button
            android:id="@+id/logoutBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:layout_marginTop="10dp"
            android:backgroundTint="#ED0909"
            android:textColor="#F2F2F2"
            android:visibility="gone"/>




    </LinearLayout>

<!--    Below is our progress bar-->
    <ProgressBar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/progressbar"/>


<!--    Below is our recyclerView-->

    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/recyclerView"
        tools:listitem="@layout/single_item"/>







</LinearLayout>